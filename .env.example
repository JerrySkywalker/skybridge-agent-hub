PORT=8787
HOST=0.0.0.0
SKYBRIDGE_DB_FILE=.data/skybridge.sqlite
SKYBRIDGE_DATA_FILE=.data/skybridge-store.json
SKYBRIDGE_PUBLIC_URL=http://127.0.0.1:3000
VITE_SKYBRIDGE_API_BASE=http://127.0.0.1:8787
NTFY_TOPIC_URL=
NTFY_TOKEN=
APPRISE_URL=
GOTIFY_URL=
BARK_URL=
WECOM_WEBHOOK_URL=
FCM_SERVER_KEY=
XIAOMI_PUSH_SECRET=
SKYBRIDGE_CLOUD_URL=http://127.0.0.1:8787
SKYBRIDGE_NODE_ID=local-devbox
SKYBRIDGE_NODE_LABELS=local,dev
SKYBRIDGE_NODE_CAPABILITIES=event-forwarding,heartbeat,spool
SKYBRIDGE_REMOTE_CONTROL_ENABLED=false
# Optional server-side Hermes adapter config for Manual Task Queue.
# Leave placeholders empty unless the SkyBridge server is allowed to call Hermes.
HERMES_API_BASE=
HERMES_API_KEY=
HERMES_API_KEY_FILE=
HERMES_TIMEOUT_MS=60000
HERMES_MAX_RESPONSE_CHARS=2000
