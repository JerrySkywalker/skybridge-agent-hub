{
  "name": "skybridge-agent-hub",
  "private": true,
  "version": "0.1.0",
  "description": "Agent-agnostic local/cloud control plane for AI-assisted software development with planner, executor, SCM/CI, notification, and runtime adapters.",
  "type": "module",
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "dev": "corepack pnpm -r --parallel --filter \"./apps/*\" dev",
    "lint": "corepack pnpm -r lint",
    "typecheck": "corepack pnpm -r typecheck",
    "test": "corepack pnpm -r test",
    "build": "corepack pnpm -r build",
    "format": "prettier --write .",
    "smoke:operator-console": "pwsh -ExecutionPolicy Bypass -File ./scripts/powershell/smoke-operator-console.ps1 -UseTempDatabase",
    "smoke:product-console": "pwsh -ExecutionPolicy Bypass -File ./scripts/powershell/smoke-product-console.ps1",
    "smoke:agent-agnostic-core": "pwsh -ExecutionPolicy Bypass -File ./scripts/powershell/smoke-agent-agnostic-core.ps1",
    "smoke:adapter-registry": "pwsh -ExecutionPolicy Bypass -File ./scripts/powershell/smoke-adapter-registry.ps1",
    "smoke:release-dry-run": "pwsh -ExecutionPolicy Bypass -File ./scripts/powershell/smoke-release-dry-run.ps1",
    "smoke:self-hosting-dry-run": "pwsh -ExecutionPolicy Bypass -File ./scripts/powershell/smoke-self-hosting-dry-run.ps1",
    "smoke:codex-hook-integration": "pwsh -ExecutionPolicy Bypass -File ./scripts/powershell/smoke-codex-hook-integration.ps1 -ApiBase http://127.0.0.1:8798 -StartServer",
    "smoke:multi-agent-platform": "pwsh -ExecutionPolicy Bypass -File ./scripts/powershell/smoke-multi-agent-platform.ps1 -ApiBase http://127.0.0.1:8799 -StartServer",
    "smoke:dogfooding-loop": "pwsh -ExecutionPolicy Bypass -File ./scripts/powershell/smoke-dogfooding-loop.ps1 -ApiBase http://127.0.0.1:8800 -StartServer",
    "smoke:release-candidate": "pwsh -ExecutionPolicy Bypass -File ./scripts/powershell/smoke-release-candidate.ps1",
    "smoke:self-observation": "pwsh -ExecutionPolicy Bypass -File ./scripts/powershell/smoke-self-observation.ps1",
    "smoke:browser-visual-qa": "pwsh -ExecutionPolicy Bypass -File ./scripts/powershell/smoke-browser-visual-qa.ps1 -SkipWhenUnavailable",
    "smoke:bootstrap-notification": "pwsh -ExecutionPolicy Bypass -File ./scripts/powershell/smoke-bootstrap-notification.ps1",
    "smoke:admin-escalation-readiness": "pwsh -ExecutionPolicy Bypass -File ./scripts/powershell/smoke-admin-escalation-readiness.ps1",
    "smoke:admin-escalation-test": "pwsh -ExecutionPolicy Bypass -File ./scripts/powershell/smoke-admin-escalation-test.ps1",
    "smoke:hermes-exposure-readiness": "pwsh -ExecutionPolicy Bypass -File ./scripts/powershell/smoke-hermes-exposure-readiness.ps1",
    "smoke:bootstrap-env-loading": "pwsh -ExecutionPolicy Bypass -File ./scripts/powershell/smoke-bootstrap-env-loading.ps1",
    "smoke:codex-phone-notification": "pwsh -ExecutionPolicy Bypass -File ./scripts/powershell/smoke-codex-phone-notification.ps1 -DryRun",
    "smoke:iteration-controller": "pwsh -ExecutionPolicy Bypass -File ./scripts/powershell/smoke-iteration-controller.ps1",
    "smoke:ci-guardian": "pwsh -ExecutionPolicy Bypass -File ./scripts/powershell/smoke-ci-guardian.ps1",
    "smoke:edge-worker-register": "pwsh -ExecutionPolicy Bypass -File ./scripts/powershell/smoke-edge-worker-register.ps1",
    "smoke:edge-worker-claim": "pwsh -ExecutionPolicy Bypass -File ./scripts/powershell/smoke-edge-worker-claim.ps1",
    "smoke:codex-task-runner": "pwsh -ExecutionPolicy Bypass -File ./scripts/powershell/smoke-codex-task-runner.ps1 -DryRun",
    "smoke:auto-merge-policy": "pwsh -ExecutionPolicy Bypass -File ./scripts/powershell/smoke-auto-merge-policy.ps1",
    "smoke:github-automation-readiness": "pwsh -ExecutionPolicy Bypass -File ./scripts/powershell/smoke-github-automation-readiness.ps1",
    "smoke:hermes-supervisor-flow": "pwsh -ExecutionPolicy Bypass -File ./scripts/powershell/smoke-hermes-supervisor-flow.ps1",
    "smoke:hermes-supervisor-operational": "pwsh -ExecutionPolicy Bypass -File ./scripts/powershell/smoke-hermes-supervisor-operational.ps1",
    "smoke:hermes-planner": "pwsh -ExecutionPolicy Bypass -File ./scripts/powershell/smoke-hermes-planner.ps1 -DryRun",
    "smoke:hermes-evaluate-result": "pwsh -ExecutionPolicy Bypass -File ./scripts/powershell/smoke-hermes-evaluate-result.ps1 -DryRun",
    "smoke:self-bootstrap-loop": "pwsh -ExecutionPolicy Bypass -File ./scripts/powershell/smoke-self-bootstrap-loop.ps1 -DryRun",
    "smoke:self-bootstrap-readiness": "pwsh -ExecutionPolicy Bypass -File ./scripts/powershell/smoke-self-bootstrap-readiness.ps1",
    "smoke:task-hygiene-report": "pwsh -ExecutionPolicy Bypass -File ./scripts/powershell/smoke-task-hygiene-report.ps1",
    "smoke:worker-heartbeat-proof": "pwsh -ExecutionPolicy Bypass -File ./scripts/powershell/smoke-worker-heartbeat-proof.ps1",
    "smoke:public-docs-no-private-endpoints": "pwsh -ExecutionPolicy Bypass -File ./scripts/powershell/smoke-public-docs-no-private-endpoints.ps1",
    "smoke:api-base-diagnostics": "pwsh -ExecutionPolicy Bypass -File ./scripts/powershell/smoke-api-base-diagnostics.ps1",
    "smoke:github-actions-hygiene": "pwsh -ExecutionPolicy Bypass -File ./scripts/powershell/smoke-github-actions-hygiene.ps1",
    "smoke:goal-305": "pwsh -ExecutionPolicy Bypass -File ./scripts/powershell/smoke-cloud-autodeploy-verify.ps1 && pwsh -ExecutionPolicy Bypass -File ./scripts/powershell/smoke-cloud-autodeploy-create-rc-tag.ps1 && pwsh -ExecutionPolicy Bypass -File ./scripts/powershell/smoke-current-pr-status.ps1 && pwsh -ExecutionPolicy Bypass -File ./scripts/powershell/smoke-goal-305-script-safety.ps1",
    "nightly:local-validation": "pwsh -ExecutionPolicy Bypass -File ./scripts/powershell/nightly-local-validation.ps1",
    "check": "corepack pnpm lint && corepack pnpm typecheck && corepack pnpm test && corepack pnpm build"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "tsx": "^4.19.4",
    "vitest": "^3.1.4"
  }
}
