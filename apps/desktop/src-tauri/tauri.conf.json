{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SkyBridge Desktop",
  "version": "0.1.0",
  "identifier": "space.jerryskywalker.skybridge.desktop",
  "build": {
    "beforeDevCommand": "corepack pnpm dev",
    "beforeBuildCommand": "corepack pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SkyBridge Desktop",
        "width": 980,
        "height": 760,
        "minWidth": 760,
        "minHeight": 560
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": false
    },
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png", "icons/icon.ico"]
  }
}
