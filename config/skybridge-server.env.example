# SkyBridge Server cloud deployment example.
# Copy to a server-local env file and replace placeholders there.
# Do not commit real tokens or credentials.

NODE_ENV=production
SKYBRIDGE_HOST=0.0.0.0
SKYBRIDGE_PORT=8787
HOST=0.0.0.0
PORT=8787
SKYBRIDGE_DB_FILE=/data/skybridge.sqlite
SKYBRIDGE_WORKER_TOKEN=<set-on-server>
SKYBRIDGE_WORKER_TOKENS_FILE=
SKYBRIDGE_PUBLIC_BASE_URL=https://skybridge.example.com
SKYBRIDGE_REQUIRE_WORKER_AUTH=true

# Optional notification provider placeholders.
NTFY_TOPIC_URL=
NTFY_TOKEN=
