{
  "mode": "ThesisYOLO",
  "maxParallel": 1,
  "maxRepairRounds": 3,
  "lockStaleMinutes": 240,
  "push": true,
  "autoPR": false,
  "createPR": false,
  "sandbox": "workspace-write",
  "notifications": {
    "provider": "ntfy",
    "onlyImportant": true,
    "environment": {
      "url": "NTFY_URL",
      "topic": "NTFY_TOPIC"
    }
  },
  "goals": {
    "ready": "./goals/ready",
    "doing": "./goals/doing",
    "done": "./goals/done",
    "failed": "./goals/failed"
  },
  "runs": {
    "directory": "./.agent/runs"
  }
}
