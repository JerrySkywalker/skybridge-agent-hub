{
  "project": {
    "id": "generic-node-app",
    "name": "Generic Node App",
    "repository": "OWNER/REPOSITORY",
    "localPath": "C:/src/generic-node-app",
    "baseBranch": "main",
    "branchPrefix": "ai/"
  },
  "core": {
    "agentAgnostic": true,
    "defaultPlannerAdapter": "rule-based-planner",
    "defaultExecutorAdapter": "manual-executor"
  },
  "executorAdapters": {
    "codex": {
      "enabled": false,
      "command": "codex",
      "args": ["exec", "--json"],
      "sandbox": "workspace-write",
      "approvalPolicy": "never",
      "outputLastMessage": true
    },
    "manual": {
      "enabled": true
    }
  },
  "goals": {
    "queuePath": "goals/ready",
    "donePath": "goals/done",
    "failedPath": "goals/failed"
  },
  "iteration": {
    "maxRepairAttempts": 2,
    "localCheckCommands": ["corepack pnpm check"],
    "smokeCommands": []
  },
  "scmProviders": {
    "github": {
      "requiredChecks": ["Project check"],
      "createPR": true,
      "watchCI": true,
      "autoMerge": false
    },
    "generic": {
      "enabled": true
    }
  },
  "notificationProviders": {
    "bootstrap": true,
    "ntfy": {
      "enabled": false,
      "topicEnv": "NTFY_TOPIC_URL"
    },
    "wecom": {
      "urgentEnv": "WECOM_WEBHOOK_URL"
    },
    "generic": {
      "enabled": true
    }
  },
  "skybridge": {
    "apiBase": "http://127.0.0.1:8787",
    "telemetryEnabled": false,
    "failOpen": true
  },
  "plannerAdapters": {
    "ruleBased": {
      "enabled": true
    },
    "hermes": {
      "enabled": false,
      "supervisorId": "hermes-generic-supervisor",
      "bridgeScript": "scripts/powershell/skybridge-hermes-supervisor.ps1"
    }
  }
}
