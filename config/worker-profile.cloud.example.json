  "allow_production_deploy": false,
  "skybridge_api_base": "https://skybridge.example.invalid",
  "auth_mode": "worker-token",
  "token_env_var": "SKYBRIDGE_WORKER_TOKEN",
  "codex_command": "codex",
  "codex_sandbox": "workspace-write"
}
