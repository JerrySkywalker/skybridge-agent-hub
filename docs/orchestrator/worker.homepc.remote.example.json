{
  "worker_id": "homepc-remote-codex-worker",
  "display_name": "Home PC Remote Codex worker",
  "project_ids": ["skybridge-agent-hub"],
  "allowed_project_ids": ["skybridge-agent-hub"],
  "repo_paths": {
    "skybridge-agent-hub": "V:\\src\\skybridge-agent-hub"
  },
  "capabilities": ["codex-exec", "filesystem", "git", "tests", "docs"],
  "executor_adapters": ["codex"],
  "preferred_task_types": ["docs", "code", "test"],
  "blocked_task_types": ["deploy", "secrets", "production", "server-root-config", "github-settings"],
  "max_parallel_tasks": 1,
  "allow_auto_merge": false,
  "allow_production_deploy": false,
  "allow_remote_server": true,
  "reject_insecure_http_for_remote": true,
  "skybridge_api_base": "https://skybridge.example.com",
  "auth_mode": "bearer_token",
  "token_env_var": "SKYBRIDGE_WORKER_TOKEN",
  "token_file": "C:\\Users\\operator\\.skybridge\\worker-token.txt",
  "codex_command": "codex",
  "codex_sandbox": "workspace-write"
}
